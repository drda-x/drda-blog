  <entry>
    <author>
      <name>Drda</name>
    </author>
    <category term="博客" scheme="https://drda-x.github.io/drda-blog/categories/%E5%8D%9A%E5%AE%A2/"/>
    <category term="hexo" scheme="https://drda-x.github.io/drda-blog/tags/hexo/"/>
